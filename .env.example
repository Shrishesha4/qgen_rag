# =============================================================================
# QuestionGeneration AI - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# =============================================================================

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
POSTGRES_USER=qgen_user
POSTGRES_PASSWORD=qgen_password
POSTGRES_DB=qgen_db
POSTGRES_PORT=5432

# =============================================================================
# Redis
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# Security
# =============================================================================
# IMPORTANT: Change this to a secure random value in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# Ollama LLM
# =============================================================================
# For local Ollama installation (recommended for GPU):
#   macOS/Windows: http://host.docker.internal:11434
#   Linux: http://host.docker.internal:11434 (with extra_hosts in docker-compose)
#
# For Docker-based Ollama:
#   http://ollama:11434 (uncomment ollama service in docker-compose.yml)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# LLM Model Selection
# Recommended models (speed vs quality):
#   - llama3.2:3b-instruct-q4_K_M   (fastest, ~3GB VRAM)
#   - llama3.1:8b-instruct-q4_K_M   (balanced, ~6GB VRAM)
#   - llama3.1:70b-instruct-q4_K_M  (best, ~40GB VRAM)
#   - mistral:7b-instruct-q4_K_M    (alternative, ~5GB VRAM)
#   - qwen2.5:7b-instruct-q4_K_M    (strong reasoning, ~5GB VRAM)
OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M

# =============================================================================
# Embedding Model
# =============================================================================
# Options:
#   - all-MiniLM-L6-v2      (384 dims, fast, good quality) - DEFAULT
#   - all-mpnet-base-v2     (768 dims, better quality, slower)
#   - BAAI/bge-base-en-v1.5 (768 dims, best for Q&A tasks)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Instruction-based embeddings (required for BGE models)
# Set to true when using BAAI/bge-* models
EMBEDDING_USE_INSTRUCTION=false

# Embedding Cache
# L1: In-memory LRU cache (always enabled)
# L2: Redis persistent cache
EMBEDDING_REDIS_CACHE=true
EMBEDDING_CACHE_TTL=604800

# =============================================================================
# Reranker (Cross-Encoder)
# =============================================================================
# Improves retrieval precision by reranking initial results
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# =============================================================================
# Document Processing
# =============================================================================
MAX_UPLOAD_SIZE_MB=50

# Chunking configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =============================================================================
# Question Generation
# =============================================================================
MAX_QUESTIONS_PER_REQUEST=50

# =============================================================================
# Rate Limiting
# =============================================================================
# Maximum requests per window per user
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# =============================================================================
# Logging & Monitoring
# =============================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Set to true for production (JSON structured logs for log aggregation)
LOG_JSON=false

# Prometheus metrics endpoint at /metrics
ENABLE_METRICS=true

# =============================================================================
# API Server
# =============================================================================
API_PORT=8000
