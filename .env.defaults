
# ── Database (Docker Compose) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=qgen_user
POSTGRES_PASSWORD=qgen_password
POSTGRES_DB=qgen_db

# ── Redis (Docker Compose) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── API (Docker Compose) ──
API_HOST=0.0.0.0
API_PORT=8000

# ── Secrets (passed to containers) ──
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM Provider ──
LLM_PROVIDER=deepseek
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_SAFETY_BLOCK_NONE=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── File Upload ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ── CORS ──
CORS_ORIGINS=*

# ── Embedding Model ──
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_REDIS_CACHE=true
EMBEDDING_CACHE_TTL=604800

# ── Reranker ──
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v1
RERANKER_ENABLED=true

# ── Question Generation ──
MAX_QUESTIONS_PER_REQUEST=50
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# ── OCR Settings ──
OCR_ENABLED=true
OCR_MIN_TEXT_PER_PAGE=50
OCR_SPARSE_THRESHOLD=0.3
OCR_LANGUAGE=eng
OCR_MAX_RETRIES=2
OCR_DPI=300

# ── Logging ──
LOG_LEVEL=info
LOG_JSON=false
ENABLE_METRICS=true

# ── Training and Promotion Gates ──
PROMOTION_MIN_OFFLINE_PASS_RATE=0.8
PROMOTION_MAX_CANARY_APPROVE_DROP=0.02
PROMOTION_MAX_CRITICAL_REJECT_INCREASE=0.01
PROMOTION_MAX_P95_LATENCY_MS=2500
PROMOTION_MAX_TIMEOUT_RATE=0.02

# ── Queue Configuration ──
QUEUE_MAX_RETRIES=3
QUEUE_DEAD_LETTER_PREFIX=dlq

# ── Generation Controls ──
ENABLE_TWO_PASS_GENERATION=false
GENERATION_SCHEMA_ENFORCEMENT=true
QUICK_GENERATE_PARALLEL_WORKERS=6
QUESTION_DEDUPE_SIMILARITY_THRESHOLD=0.987
QUESTION_OPTION_SIMILARITY_THRESHOLD=0.877

# ── Training Pipeline ──
TRAINING_DATA_DIR=./training_data
LORA_ADAPTERS_DIR=./lora_adapters
TRAINING_BASE_MODEL=deepseek-ai/DeepSeek-R1-Distill-Llama-1.7B

# ── Frontend Development Port ──
TRAINER_WEB_PORT=5173
