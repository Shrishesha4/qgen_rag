# ==============================================================================
# QGen RAG Configuration
# Generated by setup script
# ==============================================================================

# ── Database Configuration ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=qgen_user
POSTGRES_PASSWORD=qgen_password
POSTGRES_DB=qgen_db

# ── Redis Configuration ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL_OVERRIDE=

# ── API Configuration ──
API_PORT=8000

# ── Secrets ──
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM Provider ──
LLM_PROVIDER=ollama
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gpt-oss:20b
OLLAMA_MODEL=llama3.2:3b

# ── CORS ──
CORS_ORIGINS=*

# ── File Upload ──
UPLOAD_DIR=./.data/uploads
MAX_UPLOAD_SIZE_MB=500

# ── Embedding Model ──
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_REDIS_CACHE=true
EMBEDDING_CACHE_TTL=604800

# ── Reranker ──
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v1
RERANKER_ENABLED=true

# ── Question Generation ──
MAX_QUESTIONS_PER_REQUEST=500
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# ── OCR Settings ──
OCR_ENABLED=true
OCR_MIN_TEXT_PER_PAGE=50
OCR_LANGUAGE=eng

# ── Logging & Monitoring ──
LOG_LEVEL=info
LOG_JSON=false
ENABLE_METRICS=true

# ── Generation Controls ──
ENABLE_TWO_PASS_GENERATION=true
GENERATION_SCHEMA_ENFORCEMENT=true
QUICK_GENERATE_PARALLEL_WORKERS=10
QUESTION_DEDUPE_SIMILARITY_THRESHOLD=0.987
QUESTION_OPTION_SIMILARITY_THRESHOLD=0.877

# ── Queue Configuration ──
QUEUE_MAX_RETRIES=4
QUEUE_DEAD_LETTER_PREFIX=dlq

# ── Training Pipeline ──
TRAINING_DATA_DIR=./.data/training_data
LORA_ADAPTERS_DIR=./.data/lora_adapters
TRAINING_BASE_MODEL=meta-llama/Llama-3.2-3B-Instruct

# ── Auto-Training Schedule ──
AUTO_TRAINING_ENABLED=true
AUTO_TRAINING_TIMEZONE=Asia/Kolkata
AUTO_TRAINING_HOUR=11
AUTO_TRAINING_MINUTE=30
AUTO_TRAINING_METHOD=sft+dpo