{
  "deployment_modes": {
    "database_deployment": "docker",
    "backend_deployment": "docker", 
    "frontend_deployment": "docker"
  },
  "basic_settings": {
    "install_dir": "/opt/qgen",
    "domain": "localhost",
    "environment": "production",
    "debug": "false",
    "log_level": "INFO"
  },
  "database_config": {
    "postgres_db": "qgen_rag",
    "postgres_user": "qgen_user",
    "postgres_password": "qgen_password",
    "postgres_port": 5432,
    "postgres_host": "localhost",
    "postgres_data_volume": "postgres_data",
    "postgres_restart": "unless-stopped",
    "redis_password": "redis_password",
    "redis_port": 6379,
    "redis_host": "localhost",
    "redis_data_volume": "redis_data",
    "redis_restart": "unless-stopped"
  },
  "service_ports": {
    "backend_port": 8000,
    "frontend_port": 5173,
    "nginx_port": 80,
    "metrics_port": 9090
  },
  "api_configuration": {
    "api_v1_prefix": "/api/v1",
    "cors_origins": ["http://localhost:5173", "http://localhost:3000"],
    "max_request_size": "16MB",
    "access_token_expire_minutes": 30,
    "refresh_token_expire_days": 7,
    "algorithm": "HS256"
  },
  "api_keys": {
    "openai_api_key": "",
    "deepseek_api_key": "",
    "anthropic_api_key": "",
    "huggingface_api_key": ""
  },
  "model_configuration": {
    "base_model": "deepseek-ai/DeepSeek-R1-Distill-Llama-8B",
    "model_cache_dir": "/opt/qgen/models",
    "default_max_tokens": 4096,
    "default_temperature": 0.7,
    "torch_dtype": "float16",
    "device_map": "auto",
    "trust_remote_code": true,
    "use_cache": true,
    "attn_implementation": "flash_attention_2"
  },
  "training_configuration": {
    "training_data_dir": "/opt/qgen/training_data",
    "lora_adapters_dir": "/opt/qgen/lora_adapters",
    "batch_size": 4,
    "max_batch_size": 8,
    "learning_rate": 2e-4,
    "gradient_accumulation_steps": 8,
    "num_epochs": 3,
    "warmup_steps": 100,
    "save_steps": 500,
    "eval_steps": 500,
    "logging_steps": 10,
    "max_grad_norm": 1.0,
    "weight_decay": 0.01,
    "adam_epsilon": 1e-8
  },
  "lora_configuration": {
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
    "lora_dropout": 0.1,
    "lora_bias": "none",
    "lora_task_type": "CAUSAL_LM",
    "lora_modules_to_save": null
  },
  "data_configuration": {
    "train_test_split": 0.8,
    "validation_split": 0.1,
    "max_samples_per_subject": 1000,
    "quality_threshold": 0.7,
    "diversity_threshold": 0.6,
    "min_vetting_score": 4.0,
    "data_augmentation": true,
    "shuffle_data": true
  },
  "evaluation_configuration": {
    "evaluation_metrics": ["accuracy", "f1", "bleu", "rouge"],
    "evaluation_frequency": "epoch",
    "save_best_model": true,
    "early_stopping_patience": 3,
    "load_best_model_at_end": true,
    "greater_is_better": true
  },
  "optimization_configuration": {
    "optimizer": "adamw",
    "scheduler": "cosine",
    "fp16": true,
    "bf16": false,
    "gradient_checkpointing": true,
    "dataloader_num_workers": 4,
    "remove_unused_columns": true
  },
  "directory_paths": {
    "model_cache_dir": "/opt/qgen/models",
    "training_data_dir": "/opt/qgen/training_data",
    "lora_adapters_dir": "/opt/qgen/lora_adapters",
    "upload_dir": "/opt/qgen/uploads",
    "logs_dir": "/opt/qgen/logs",
    "ssl_dir": "/opt/qgen/ssl",
    "backups_dir": "/opt/qgen/backups",
    "temp_dir": "/opt/qgen/temp"
  },
  "ssl_configuration": {
    "ssl_type": "self_signed",
    "ssl_email": "admin@example.com",
    "ssl_country": "US",
    "ssl_state": "State",
    "ssl_city": "City",
    "ssl_organization": "Organization",
    "ssl_days": 365,
    "ssl_cert_path": "/opt/qgen/ssl/cert.pem",
    "ssl_key_path": "/opt/qgen/ssl/key.pem",
    "force_https": "false"
  },
  "frontend_configuration": {
    "public_api_url": "http://localhost:8000",
    "public_ws_url": "ws://localhost:8000",
    "public_api_version": "v1",
    "public_app_name": "QGen RAG",
    "public_app_version": "1.0.0",
    "public_app_description": "Question Generation System",
    "public_enable_analytics": "true",
    "public_enable_dark_mode": "true",
    "public_enable_notifications": "true",
    "public_default_theme": "light",
    "public_default_language": "en",
    "public_page_size": "20",
    "public_dev_mode": "false",
    "public_log_level": "INFO"
  },
  "trainer_web_configuration": {
    "trainer_api_url": "http://localhost:8000",
    "trainer_ws_url": "ws://localhost:8000",
    "trainer_app_title": "QGen RAG Trainer",
    "trainer_app_description": "Training Interface for QGen RAG",
    "trainer_default_model": "deepseek-ai/DeepSeek-R1-Distill-Llama-8B",
    "trainer_max_tokens": "4096",
    "trainer_default_temperature": "0.7",
    "trainer_theme": "default",
    "trainer_language": "en",
    "trainer_timezone": "UTC",
    "trainer_enable_advanced_mode": "true",
    "trainer_enable_experimental": "false",
    "trainer_enable_debug": "false"
  },
  "mobile_configuration": {
    "setup_mobile_client": false,
    "mobile_platform": "ios",
    "mobile_build_command": "npm run build"
  },
  "file_upload_configuration": {
    "max_file_size": "50MB",
    "allowed_extensions": ["pdf", "docx", "txt", "csv", "xlsx"],
    "upload_chunk_size": "8MB",
    "max_concurrent_uploads": 3
  },
  "monitoring_configuration": {
    "enable_metrics": "true",
    "metrics_port": 9090,
    "sentry_dsn": "",
    "log_level": "INFO",
    "logging_strategy": "steps",
    "report_to": ["tensorboard", "wandb"],
    "project_name": "qgen-rag",
    "run_name": "training-session"
  },
  "docker_configuration": {
    "backend_dockerfile": "Dockerfile",
    "frontend_dockerfile": "Dockerfile",
    "backend_memory_limit": "2G",
    "backend_cpu_limit": "1.0",
    "backend_memory_reservation": "1G",
    "backend_cpu_reservation": "0.5",
    "backend_restart": "unless-stopped",
    "frontend_restart": "unless-stopped",
    "training_worker_restart": "unless-stopped",
    "models_volume": "./models",
    "training_data_volume": "./training_data",
    "lora_adapters_volume": "./lora_adapters",
    "logs_volume": "./logs"
  },
  "baremetal_configuration": {
    "backend_user": "qgen",
    "backend_group": "qgen",
    "backend_host": "0.0.0.0",
    "backend_workers": "1",
    "cuda_visible_devices": "0"
  },
  "nginx_configuration": {
    "nginx_port": 80,
    "nginx_ssl_port": 443,
    "nginx_worker_processes": "auto",
    "nginx_worker_connections": 1024
  },
  "repository_configuration": {
    "repository_url": "https://github.com/your-org/qgen_rag.git",
    "repository_branch": "main",
    "repository_depth": 1
  },
  "data_initialization": {
    "init_sample_data": true,
    "create_admin_user": true,
    "admin_username": "admin",
    "admin_email": "admin@example.com",
    "admin_password": "admin123"
  },
  "feature_flags": {
    "enable_gpu_acceleration": true,
    "enable_model_caching": true,
    "enable_data_compression": true,
    "enable_audit_logging": true,
    "enable_rate_limiting": true,
    "enable_caching": true,
    "enable_compression": true,
    "enable_cors": true
  },
  "security_configuration": {
    "enable_authentication": true,
    "enable_authorization": true,
    "session_timeout": 3600,
    "max_login_attempts": 5,
    "password_min_length": 8,
    "require_email_verification": false,
    "enable_two_factor": false
  },
  "performance_configuration": {
    "database_pool_size": 10,
    "database_max_overflow": 20,
    "redis_pool_size": 10,
    "cache_ttl": 3600,
    "request_timeout": 30,
    "worker_timeout": 300
  },
  "backup_configuration": {
    "enable_backups": true,
    "backup_frequency": "daily",
    "backup_retention_days": 30,
    "backup_compression": true,
    "backup_encryption": false,
    "backup_location": "/opt/qgen/backups"
  }
}
