POSTGRES_USER=qgen_user
POSTGRES_PASSWORD=qgen_password
POSTGRES_DB=qgen_db
POSTGRES_PORT=5432
REDIS_PORT=6379
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_SAFETY_BLOCK_NONE=true

# Embedding: nomic-embed-text via Ollama (768 dims, 8192 context window)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_USE_INSTRUCTION=false
EMBEDDING_REDIS_CACHE=true
EMBEDDING_CACHE_TTL=604800

# Reranker: mxbai-rerank-large-v1 (BERT cross-encoder, GPU-accelerated)
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v1
RERANKER_ENABLED=true

# Auth database (SQLite, decoupled from pgvector)
AUTH_DATABASE_URL=sqlite+aiosqlite:///./auth.db
MAX_UPLOAD_SIZE_MB=500

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_QUESTIONS_PER_REQUEST=50

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600
LOG_LEVEL=info

LOG_JSON=false

ENABLE_METRICS=true

API_PORT=8000

CORS_ORIGINS=*

DEV_MACHINE_IP=10.0.0.4

USE_SIMULATOR=flase

PRODUCTION_API_URL=http://10.0.0.4:8000/api/v1

USE_PRODUCTION_API=true