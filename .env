# CampusLearn - Environment Configuration
# Customize for your environment

# === Mobile App (iOS/Android) ===
DEV_MACHINE_IP=192.168.1.101
USE_SIMULATOR=false
PRODUCTION_API_URL=
USE_PRODUCTION_API=false

# === Database ===
POSTGRES_USER=qgen_user
POSTGRES_PASSWORD=qgen_password
POSTGRES_DB=qgen_db
POSTGRES_PORT=5432

# === Redis ===
REDIS_PORT=6379

# === Security ===
# IMPORTANT: Generate random key with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# === LLM & AI ===
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
GEMINI_API_KEY=
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_REDIS_CACHE=true
EMBEDDING_CACHE_TTL=604800
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# === Documents & Questions ===
MAX_UPLOAD_SIZE_MB=500
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# === API ===
API_PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=info
ENABLE_METRICS=true

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600
