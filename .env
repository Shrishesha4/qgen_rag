POSTGRES_USER=qgen_user
POSTGRES_PASSWORD=qgen_password
POSTGRES_DB=qgen_db
POSTGRES_PORT=5432
REDIS_PORT=6379
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_SAFETY_BLOCK_NONE=true

# =============================================================================
# Embedding Model
# =============================================================================
# Options:
#   - all-MiniLM-L6-v2      (384 dims, fast, good quality) - DEFAULT
#   - all-mpnet-base-v2     (768 dims, better quality, slower)
#   - BAAI/bge-base-en-v1.5 (768 dims, best for Q&A tasks)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# Instruction-based embeddings (required for BGE models)
# Set to true when using BAAI/bge-* models
EMBEDDING_USE_INSTRUCTION=true
EMBEDDING_REDIS_CACHE=true
EMBEDDING_CACHE_TTL=604800
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true
MAX_UPLOAD_SIZE_MB=500

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_QUESTIONS_PER_REQUEST=50

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600
LOG_LEVEL=info

LOG_JSON=false

ENABLE_METRICS=true

API_PORT=8000

CORS_ORIGINS=*

DEV_MACHINE_IP=172.23.25.251

USE_SIMULATOR=true

PRODUCTION_API_URL=

USE_PRODUCTION_API=false